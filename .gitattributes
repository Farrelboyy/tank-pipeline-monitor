# Normalize line endings for all text files
* text=auto

# Explicitly set JS/JSX/CSS/HTML/JSON to LF
*.js   text eol=lf
*.jsx  text eol=lf
*.css  text eol=lf
*.html text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.sql  text eol=lf
*.env* text eol=lf

# Binary files
*.db     binary
*.sqlite binary
*.png    binary
*.jpg    binary
*.ico    binary
